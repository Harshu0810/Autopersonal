        "def extract_drive_id(url: str) -> str:\n",
        "    patterns = [\n",
        "        r\"/file/d/([a-zA-Z0-9_-]+)\",\n",
        "        r\"/folders/([a-zA-Z0-9_-]+)\"\n",
        "    ]\n",
        "    for p in patterns:\n",
        "        m = re.search(p, url)\n",
        "        if m:\n",
        "            return m.group(1)\n",
        "    raise ValueError(\"Invalid Google Drive link\")"
      ],
